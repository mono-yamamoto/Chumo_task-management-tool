        {
          "type": "frame",
          "id": "X76gs",
          "name": "Usage",
          "width": "fill_container",
          "fill": "transparent",
          "layout": "vertical",
          "gap": 32,
          "children": [
            {
              "type": "text",
              "id": "a5hdw",
              "name": "usageTitle",
              "fill": "$--color-text-primary",
              "content": "Usage",
              "fontFamily": "Plus Jakarta Sans",
              "fontSize": "$--font-size-3xl",
              "fontWeight": "$--font-weight-bold"
            },
            {
              "type": "text",
              "id": "8nVT3",
              "name": "usageDesc",
              "fill": "$--color-text-primary",
              "textGrowth": "fixed-width",
              "width": 804,
              "content": "全般的には原則Bodyを使い、見出しや補足分、その他UIに他の定義を使う。\nBodyとNoteの行間の定義は複数あり、150%（normal）をデフォルトとする。レイアウトの都合にあわせて*-narrow（175%）、*-tight（125%）を使い分ける。",
              "lineHeight": "$--line-height-relaxed",
